" content=\"text/html; charset=UTF-8\">\n  <meta http-equiv=\"pragma\" content=\"no-cache\">\n  <meta http-equiv=\"Cache-Control\" content=\"no-cache,must-revalidate\">\n  <script id=\"common_js\" type=\"text/javascript\" src=\"/resource/js/common.js\"></script>\n </head>\n <body>\n  <div id=\"container\">\n   <div class=\"main-container\" id=\"main-container\">\n    <div id=\"accessNull\"></div>\n    <div id=\"skip\">\n     <a id=\"accesshelp\" title=\"新窗口打开无障碍操作说明页面\" href=\"https://jhelper.shanghai.gov.cn/wzagjt/shuoming.html\" target=\"_blank\">无障碍操作说明</a> <a href=\"javascript:createNodeDiv('mainNav', '已定位到网站导航');\" title=\"跳转到网站导航区\">跳转到网站导航区</a> <a href=\"javascript:createNodeDiv('main', '已定位到主要内容区域');\" title=\"跳转到主要内容区域\">跳转到主要内容区域</a>\n    </div><!-- 头部 -->\n    <div class=\"head\" id=\"header\">\n    </div><!-- 头部结束 -->\n    <div class=\"sub-header\">\n     <div class=\"breadcrumb\">\n      <div class=\"container\">\n       <a href=\"/index.html\" title=\"首页\">首页</a> <span>/</span> <a href=\"/ywdt/index.html\" title=\"要闻动态\">要闻动态</a> <span>/</span> <a href=\"/gqfc/index.html\" title=\"各区风采\">各区风采</a>\n      </div>\n     </div>\n    </div><!-- 主体内容 -->\n    <div class=\"sub-content\" id=\"main\">\n     <div class=\"container flex\">\n      <!-- 左侧栏 -->\n      <div class=\"f-left flex-cell\">\n       <div class=\"article-box Article\">\n        <p id=\"ivs_title\" class=\"Article-title title\">这4条“静安特色旅游路线”等你来打卡</p>\n        <p class=\"title1\"></p>\n        <p class=\"intro\" style=\"margin-top:10px;\"><span id=\"ivs_date\" class=\"Article-time date\">2024-05-30 10:06</span> <span>来源： 乐游上海 </span><br><br><span style=\"font-size: 16px;\"></span></p>\n        <div id=\"ivs_player\"></div>\n        <div class=\"Article_content article\">\n         <div id=\"ivs_content\">\n          <p>  当今，旅游业已经成为“服务美好生活、促进经济发展、构筑精神家园、展示中国形象、增进文明互鉴”的民生产业、幸福产业。这4条“静安特色线路”涵盖海派经典、潮流生活、元宇宙体验、文商旅融合等，是市民游客在初夏时节走进静安、体验生活和文旅消费的好去处。以下皆为推荐线路，非旅游产品。</p>\n          <p style=\"text-align: center;\"><strong>线路一：</strong><strong>文艺、时光、亲子，艺术苏河一次逛不够</strong></p>\n          <p>  苏州河在汇入黄浦江前，划出了一道长数公里的优美弧线，它就是静安苏河湾。在这片区域里，拥有17个风貌保护街坊，170处博物馆、美术馆、文化新空间等文旅资源点位，是中心城区独有的“一河两岸、中西合璧”滨水活力中枢。</p>\n          <p>  <strong>支线一：苏河北岸时尚文艺线路</strong></p>\n          <p>  <strong>行走路线：</strong></p>\n          <p>  苏河湾万象天地——浙江路桥——TBCA文化艺术中心——UCCA Edge静安尤伦斯美术馆——静安大悦城——SUHE HAUS苏河皓司——Fotografiska影像艺术中心——四行仓库码头—苏州河乘船游览</p>\n          <p>  <strong>宝藏点位：</strong></p>\n          <p>  ◆苏河湾万象天地</p>\n          <p>  这里地处苏河湾板块腹地，与外滩一脉相连，与陆家嘴隔江相望，是苏州河畔的新地标，这里艺术与潮流相交融，也成为更多年轻人喜欢打卡的好去处。</p>\n          <p>  地址：福建北路100号</p>\n          <p style=\"text-align: center;\"><img id=\"b7e341292c3640f09cf8b7674bc53786\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安1.png\" src=\"/cmsres/b7/b7e341292c3640f09cf8b7674bc53786/3a75e344657d4f5bb76aae6aad9b27d4.png\" alt=\"静安1.png\" data-size=\"1994093\"></p>\n          <p>  ◆浙江路桥</p>\n          <p>  浙江路桥是老桥中的“颜值担当”，作为世界上硕果仅存的几座鱼腹式钢桁架桥梁之一，这里也成为苏州河上的一道怀旧风景。</p>\n          <p style=\"text-align: center;\"><img id=\"03afdc3e306d45408a667d6a5439f64e\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安2.png\" src=\"/cmsres/03/03afdc3e306d45408a667d6a5439f64e/26af08c2469a859cbe7f0bf34456be08.png\" alt=\"静安2.png\" data-size=\"1538384\"></p>\n          <p>  ◆TBCA文化艺术中心</p>\n          <p>  TBCA文化艺术中心是坐落于苏河湾的全新艺术空间，承载了影像内容制造、创意制作、艺术策展等多项功能。旨在呈现潮流艺术，构建一个开放、流动、触发好奇与交流的艺术现场。</p>\n          <p>  地址：曲阜路9弄下沉庭院B1—6</p>\n          <p>  ◆UCCA Edge静安尤伦斯美术馆</p>\n          <p>  作为UCCA尤伦斯当代艺术中心馆群的重要组成部分，UCCA Edge静安尤伦斯美术馆致力于为公众带来国内外知名艺术家的展览。</p>\n          <p>  地址：西藏北路88号盈凯文创广场2层</p>\n          <p style=\"text-align: center;\"><img id=\"9a534d91f1ba426cb8e7bbbd8af33f92\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安3.jpg\" src=\"/cmsres/9a/9a534d91f1ba426cb8e7bbbd8af33f92/e111ccd2b421cb88fae004fd7e1940b4.jpg\" alt=\"静安3.jpg\" data-size=\"64037\"></p>\n          <p>  ◆静安大悦城</p>\n          <p>  静安大悦城网罗潮流元素，通过多元跨界、先锋引领、孵化潮流IP，吸引更多年轻人前来体验打卡，不断打造与年轻人合拍的新场域。</p>\n          <p>  地址：西藏北路166号</p>\n          <p>  ◆SUHE HAUS苏河皓司</p>\n          <p>  SUHE HAUS苏河皓司致力于与全球领先的艺术机构、画廊、品牌和创意人士合作，共同打造的一个国际化、跨领域的艺术和创意平台。</p>\n          <p>  地址：文安路30号</p>\n          <p style=\"text-align: center;\"><img id=\"d7de3546a36940bcb85b1588a7d0a8f6\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安4.png\" src=\"/cmsres/d7/d7de3546a36940bcb85b1588a7d0a8f6/b92850c06fad2a197a401e34e9a00d46.png\" alt=\"静安4.png\" data-size=\"2453817\"></p>\n          <p>  ◆Fotografiska影像艺术中心</p>\n          <p>  亚洲首家，落地静安苏河湾畔的Fotografiska影像艺术中心，自然粗粝的红砖墙传达城市意蕴，保留在地元素的同时，邀你见证中外文化艺术的奇妙交融。</p>\n          <p>  地址：光复路127号</p>\n          <p style=\"text-align: center;\"><img id=\"cdb022cb5543473bad73bcb207431b28\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安5.jpg\" src=\"/cmsres/cd/cdb022cb5543473bad73bcb207431b28/d98e11004b3cb4b4f2e0f8eae0aba590.jpg\" alt=\"静安5.jpg\" data-size=\"45310\"></p>\n          <p>  ◆上海四行仓库抗战纪念馆</p>\n          <p>  四行仓库抗战纪念馆是1937年淞沪会战中著名的“四行仓库保卫战”发生地。2014年，上海对四行仓库进行整体保护修缮，其中4000多平方米空间改建成“四行仓库抗战纪念馆”；2015年8月13日，纪念馆对外开放。</p>\n          <p>  地址：光复路21号</p>\n          <p>  开放时间：周二至周日9:00—16:30（16:00停止进馆），周一闭馆（法定节假日除外）</p>\n          <p>  ◆悠游苏州河</p>\n          <p>  乘船荡漾于苏州河上，驶过地标性建筑景观，穿行于造型别致的桥梁，了解苏河脉络及背后的故事。</p>\n          <p style=\"text-align: center;\"><img id=\"57b0b1581a5046b084d838e889b13877\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安6.png\" src=\"/cmsres/57/57b0b1581a5046b084d838e889b13877/364357c2dbdd4e589dd170583389288c.png\" alt=\"静安6.png\" data-size=\"1697412\"></p>\n          <p>  <strong>支线二：穿越苏河时光记忆线路</strong></p>\n          <p>  <strong>行走路线：</strong></p>\n          <p>  上海铁路博物馆——中共三大后中央局机关历史纪念馆——乌镇路桥——中国劳动组合书记部旧址陈列馆——上海自然博物馆——静安雕塑公园艺术中心</p>\n          <p>  <strong>宝藏点位：</strong></p>\n          <p>  ◆上海铁路博物馆</p>\n          <p>  上海铁路博物馆坐落于1909年建成、具有英式古典建筑风格的沪宁铁路上海站（老北站）旧址上。整个博物馆包括占地约1300平方米的室外广场展区和拥有3000余平方米建筑面积的博物馆主楼。室外的广场展区营造了早期上海火车站的场景，笨重的蒸汽机车和木结构的月台雨棚显得饱经岁月沧桑。</p>\n          <p>  地址：天目东路200号</p>\n          <p style=\"text-align: center;\"><img id=\"9ce77b3205b04d888e97d660e51769a5\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安7.png\" src=\"/cmsres/9c/9ce77b3205b04d888e97d660e51769a5/98d5f613872775bc027f019b10b8efe2.png\" alt=\"静安7.png\" data-size=\"1474298\"></p>\n          <p>  ◆中共三大后中央局机关历史纪念馆</p>\n          <p>  1923年，中共中央局迁至上海，从这里始发出去的号令指导了一系列革命运动。</p>\n          <p>  地址：浙江北路118号</p>\n          <p>  开放时间：周二至周日 9:00—12:00（11:30停止入馆）和13:00—16:30（16:00停止入馆），周一闭馆。</p>\n          <p style=\"text-align: center;\"><img id=\"16443c7600f545e1984609db1cf38fef\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安8.png\" src=\"/cmsres/16/16443c7600f545e1984609db1cf38fef/1eef01b6789c6bf795965a811e821bc4.png\" alt=\"静安8.png\" data-size=\"1765532\"></p>\n          <p>  ◆乌镇路桥</p>\n          <p>  一座外形沉静肃穆的简支架桥。它是解放上海时，人民解放军通过苏州河上的第一座桥，也是上海发展变迁的“见证者”。</p>\n          <p style=\"text-align: center;\"><img id=\"86caa584be304cbbae91b98b532e0aab\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安9.jpg\" src=\"/cmsres/86/86caa584be304cbbae91b98b532e0aab/675fa4004bceb26c1171a3677761ac1e.jpg\" alt=\"静安9.jpg\" data-size=\"106584\"></p>\n          <p>  ◆中国劳动组合书记部旧址陈列馆</p>\n          <p>  1921年，中国劳动组合书记部成立，是中国共产党领导工人运动的起点、中华全国总工会的摇篮。</p>\n          <p>  地址：成都北路 893 弄 1—11 号</p>\n          <p>  开放时间：周二至周日 9:00—12:00（11:30停止入馆）和13:00—16:30（16:00停止入馆），周一闭馆。</p>\n          <p style=\"text-align: center;\"><img id=\"9a5e2dd89bf540fe9e8d1004c483abee\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安10.png\" src=\"/cmsres/9a/9a5e2dd89bf540fe9e8d1004c483abee/a734fe2990a5d05998f119358291cec2.png\" alt=\"静安10.png\" data-size=\"1753848\"></p>\n          <p>  ◆上海自然博物馆</p>\n          <p>  上海自然博物馆是中国最大的自然博物馆之一，展出了上万件标本藏品，内容丰富。博物馆共有五层，常设展览有10个，分为自然演化、生命环境、人类文明三个体系。</p>\n          <p>  地址：北京西路510号，静安雕塑公园内</p>\n          <p style=\"text-align: center;\"><img id=\"791b306de34f463cb03726bf2b1c8da9\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安11.png\" src=\"/cmsres/79/791b306de34f463cb03726bf2b1c8da9/15b530bf2bc6b7aa2e71387f7e8b8b64.png\" alt=\"静安11.png\" data-size=\"1440301\"></p>\n          <p>  ◆静安雕塑公园艺术中心</p>\n          <p>  艺术中心位于静安雕塑公园内，有入口空间、接待空间、外花园空间和内花园空间，这里不定期会有艺术展览展出。2023年，上海首批十五个“美术新空间”认定公布，其中静安雕塑公园艺术中心是十五个空间中唯一一家公园绿地中的美术新空间。</p>\n          <p>  地址：石门二路128号</p>\n          <p>  <strong>支线三：苏河南岸欢乐亲子线路</strong></p>\n          <p>  <strong>行走路线：</strong></p>\n          <p>  M+马利创意园——中共中央秘书处机关旧址纪念馆——MOHO MALL——昌平路桥——蝴蝶湾公园——静安区少年儿童图书馆——元利当铺旧址博物馆——越界·陕康里</p>\n          <p>  <strong>宝藏点位：</strong></p>\n          <p>  ◆M+马利创意园</p>\n          <p>  藏在市中心小而美的艺术街区——M+马利创意园，这里曾是百年国货品牌——马利颜料生产车间的旧址，街区延续天然的色彩基因，摇身一变成了小资生活的代名词。也是集艺术展览、手工workshop、画材、图书、家居好物等于一体的文创空间。</p>\n          <p>  地址：西康路850号</p>\n          <p style=\"text-align: center;\"><img id=\"3be58d7540d94286804fed3355338e34\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安12.png\" src=\"/cmsres/3b/3be58d7540d94286804fed3355338e34/2314c2de141be24b8c9076771dd2959f.png\" alt=\"静安12.png\" data-size=\"1899572\"></p>\n          <p>  ◆中共中央秘书处机关旧址纪念馆</p>\n          <p>  1926年，中共中央秘书处成立，承担党中央重要文件资料收发、保管及中央机要工作。</p>\n          <p>  地址：江宁路673弄10号</p>\n          <p style=\"text-align: center;\"><img id=\"b936a40ddb5f46f6a8d26863e33cc47a\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安13.png\" src=\"/cmsres/b9/b936a40ddb5f46f6a8d26863e33cc47a/ee000570717fede5259125c2ccc51689.png\" alt=\"静安13.png\" data-size=\"1553828\"></p>\n          <p>  ◆MOHO MALL</p>\n          <p>  拥有多个独家原创IP空间和超50家品牌首店。如钟楼般的商场外立面展示着复古美，一层中庭的潮流棋盘艺术装置蕴含“时尚是一盘大棋”的巧妙寓意。</p>\n          <p>  地址：江宁路699号</p>\n          <p style=\"text-align: center;\"><img id=\"533bde8c977648759cef073d534aa498\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安14.jpg\" src=\"/cmsres/53/533bde8c977648759cef073d534aa498/0f11175fcf182ac6ce3457ee049149a2.jpg\" alt=\"静安14.jpg\" data-size=\"104976\"></p>\n          <p>  ◆昌平路桥</p>\n          <p>  以“苏河之眼”为设计灵感，上翘的人行道与主梁之间距离缓缓变化，仿佛一只微微睁开的眼睛。</p>\n          <p style=\"text-align: center;\"><img id=\"2917e8c0facc4b379ab9ad70b5d5baf3\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安15.png\" src=\"/cmsres/29/2917e8c0facc4b379ab9ad70b5d5baf3/08313856ef01881cd7fd14c96d2d3f6c.png\" alt=\"静安15.png\" data-size=\"1478355\"></p>\n          <p>  ◆蝴蝶湾公园</p>\n          <p>  蝴蝶湾公园是一个“宜乐宜游”的公共空间，形成一体化的滨河步道，新增了景观绿化“樱花园”及“荫生墙”。</p>\n          <p>  地址：康定东路50号</p>\n          <p style=\"text-align: center;\"><img id=\"2b4f87027cec45f5833908f783c731b2\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安16.png\" src=\"/cmsres/2b/2b4f87027cec45f5833908f783c731b2/d8b624dc41a7937b46be21749694c6ca.png\" alt=\"静安16.png\" data-size=\"1832093\"></p>\n          <p>  ◆静安区少年儿童图书馆</p>\n          <p>  地址：康定东路28号</p>\n          <p style=\"text-align: center;\"><img id=\"598699a19d2d459a86ea70d328125ca6\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安17.png\" src=\"/cmsres/59/598699a19d2d459a86ea70d328125ca6/2537128585c1f86365f76c5712fee3e4.png\" alt=\"静安17.png\" data-size=\"2961333\"></p>\n          <p>  ◆元利当铺旧址博物馆</p>\n          <p>  曾被誉为“海上第一当”，集徽派建筑和欧式风格于一体，是迄今上海仅存的规模最大和保存最完好的当铺建筑。</p>\n          <p>  地址：武定路203号</p>\n          <p style=\"text-align: center;\"><img id=\"2c616b8814234b0db6270a5eafc80c0c\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安18.jpg\" src=\"/cmsres/2c/2c616b8814234b0db6270a5eafc80c0c/8f14e29dcae23cdd2a7e0458735d33f2.jpg\" alt=\"静安18.jpg\" data-size=\"91908\"></p>\n          <p>  ◆越界·陕康里</p>\n          <p>  原为上海重要的材料工业集散地，现为隐藏在社区中充满烟火气的城市新空间。各种小店林立，艺术设计画廊Dest Gallery也落户于此。</p>\n          <p>  地址：康定路358号</p>\n          <p style=\"text-align: center;\"><img id=\"bd1992729dc04befb96e0d31da0f6e86\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安19.png\" src=\"/cmsres/bd/bd1992729dc04befb96e0d31da0f6e86/009a9e095b5627ca5dd8d2e2c7c6bfe3.png\" alt=\"静安19.png\" data-size=\"1841826\"></p>\n          <p>  </p>\n          <p style=\"text-align: center;\"><strong>线路二：慢行“巨富长”，梧桐树下品幸福滋味</strong></p>\n          <p>  “巨富长”是上海“梧桐区”里三条小马路：巨鹿路、富民路和长乐路的简称。在这里，深厚的历史文化底蕴，接地气的人间烟火，国际化的潮流前沿交织出独特的魅力，吸引你来了还想来。</p>\n          <p>  <strong>行走路线：</strong></p>\n          <p>  静安区旅游服务中心（文明旅游互动体验）——丰盛里·静安寺广场——华山路天桥——大胜胡同——华山263老字号品牌馆——上海蔡元培故居陈列馆——景华新村——LABELHOOD蕾虎——PLUSONE咖啡——JULU 758——Times Remake——合众图书馆旧址</p>\n          <p>  <strong>宝藏点位：</strong></p>\n          <p>  ◆静安区旅游服务中心</p>\n          <p>  这里是一处为国内外游客提供旅游咨询服务等的服务中心，自从更新了建筑印章，这里也成为了年轻人的网红打卡地。</p>\n          <p>  地址：安义路63号</p>\n          <p>  开放时间：每天9:00—17:00（周一闭馆）</p>\n          <p style=\"text-align: center;\"><img id=\"61b16b916fdf4cdc9ea89f008ff29f66\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安20.png\" src=\"/cmsres/61/61b16b916fdf4cdc9ea89f008ff29f66/9b50bcc02afb5412aae72721b08b6f1d.png\" alt=\"静安20.png\" data-size=\"1935341\"></p>\n          <p>  ◆丰盛里·静安寺广场</p>\n          <p>  2024年3月18日，丰盛里·静安寺广场焕新回归，正式启用。焕新后的丰盛里·静安寺广场，以轻餐饮、零售和文化等为主营业态。</p>\n          <p>  ◆华山路天桥</p>\n          <p>  位于华山路和延安西路交叉口，是上海著名的打卡胜地之一，也是上海摄影爱好者必打卡的“法师桥”。</p>\n          <p style=\"text-align: center;\"><img id=\"f628fc87b9604520b9db617fbc36b1f3\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安21.png\" src=\"/cmsres/f6/f628fc87b9604520b9db617fbc36b1f3/4e4c6d3f63872a2abb9707856ac806ba.png\" alt=\"静安21.png\" data-size=\"1627878\"></p>\n          <p>  ◆大胜胡同</p>\n          <p>  大胜胡同坐落在华山路229—293号。虽名为胡同，其实是如假包换的法式新式大型里弄住宅群，建筑风格也与北京胡同截然不同。</p>\n          <p style=\"text-align: center;\"><img id=\"acd5b23c32be4209818c010cb5247893\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安22.png\" src=\"/cmsres/ac/acd5b23c32be4209818c010cb5247893/24078025428792f50e215d11c458ad18.png\" alt=\"静安22.png\" data-size=\"1985364\"></p>\n          <p>  ◆华山263老字号品牌馆</p>\n          <p>  2022年，华山路263老字号品牌馆在此开馆，不仅展出着中华民族深厚的历史文化与人民记忆，也是上海工匠精神与商业精神的见证。</p>\n          <p>  地址：华山路263弄</p>\n          <p>  开放时间：每日9:30—17:00（周一闭馆）</p>\n          <p>  ◆上海蔡元培故居陈列馆</p>\n          <p>  上海蔡元培故居陈列馆展示了大量蔡元培先生及其家人使用过的物品，真实地再现了蔡元培先生在此生活的情景。</p>\n          <p>  地址：华山路303弄16号</p>\n          <p>  开放时间：周二至周日 9:00—12:00（11:30停止入馆）和13:00—16:30（16:00停止入馆）。另外，三楼实物馆仅每周三9:00—12:00（11:30停止入馆）和13:00—16:30（16:00停止入馆）开放。</p>\n          <p style=\"text-align: center;\"><img id=\"4d10da3e94a9438f9ecb1428feca0d58\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安23.png\" src=\"/cmsres/4d/4d10da3e94a9438f9ecb1428feca0d58/e3bdc2d45a9a1241d17ad0053e0db948.png\" alt=\"静安23.png\" data-size=\"1821836\"></p>\n          <p>  ◆景华新村</p>\n          <p>  景华新村是上海市的一处历史建筑，修建于1938年，其所在地曾是私人园林周家花园的一部分。1937年，在原周家花园南部兴建里弄房屋，因风景秀丽，故名“景华”。</p>\n          <p>  地址：巨鹿路820号</p>\n          <p>  ◆LABELHOOD 蕾虎</p>\n          <p>  LABELHOOD蕾虎是一个集结中国年轻群体的先锋时装文化体验社区，旗下拥有先锋时装艺术节和独立设计师品牌买手店。</p>\n          <p>  ◆PLUSONE 咖啡</p>\n          <p>  PLUSONE咖啡店所在的光华里曾是电影皇后胡蝶的旧居所在地。PLUSONE咖啡店是电影《爱情神话》取景地之一。</p>\n          <p>  ◆JULU 758</p>\n          <p>  JULU 758前身是上海仪表厂，上世纪90年代成为东方证券办公楼。改造后的JULU 758整体呈现工业风。</p>\n          <p style=\"text-align: center;\"><img id=\"7b39394e41304464b2efd1035a99a505\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安24.png\" src=\"/cmsres/7b/7b39394e41304464b2efd1035a99a505/a5a2ba159f8f22267590124e422895a5.png\" alt=\"静安24.png\" data-size=\"1527284\"></p>\n          <p>  ◆TIMES REMAKE</p>\n          <p>  TIMES REMAKE上海保罗花园的新空间是一个充分契合vintage和archive的陈列空间。</p>\n          <p>  ◆合众图书馆旧址</p>\n          <p>  合众图书馆专注于集纳、守护、传承中国传统文史典籍。这里也因此成为守护中华文脉的“战斗堡垒”。如今，这幢建筑正式启动保护修缮，将成为上海图书馆中华家谱主题馆。</p>\n          <p style=\"text-align: center;\"><img id=\"78fc9fe51f514f22a71d1aab17d4f657\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安25.png\" src=\"/cmsres/78/78fc9fe51f514f22a71d1aab17d4f657/97b298e1913b58e30483d1f76270c43b.png\" alt=\"静安25.png\" data-size=\"1752222\"></p>\n          <p>  </p>\n          <p style=\"text-align: center;\"><strong>线路三：文商旅体联动 国际静安“好看”又“好逛”</strong></p>\n          <p>  南京西路是“中华商业第一街”南京路的西半段，东起西藏中路，西迄延安西路，全长3833米，穿越静安寺闹市地区，横贯静安全境。南京西路沿路分布有众多历史建筑、名人故居和数家大型商业综合体，是上海最有艺术人文价值的街区之一。上海时装周、国际美妆节、上海·静安现代戏剧谷、上海国际茶文化旅游节、静安音乐节、上海静安（世界）咖啡文化节等众多大型文商旅体活动也都在这里举办。文商旅体的深度联动，不仅成为静安南京西路建设“千亿商圈”的强劲助力，也给更多市民游客提供了好看又好逛的城市生活新体验。</p>\n          <p style=\"text-align: center;\"><img id=\"5bac0e3e080d474d8dc8d92cab4ecc0b\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安26.png\" src=\"/cmsres/5b/5bac0e3e080d474d8dc8d92cab4ecc0b/c27b1ebcbedfd381751408866d501094.png\" alt=\"静安26.png\" data-size=\"1064903\"></p>\n          <p style=\"text-align: center;\">南京西路</p>\n          <p style=\"text-align: center;\"><img id=\"9160291e63ab4f3da133114bcf1d943b\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安27.png\" src=\"/cmsres/91/9160291e63ab4f3da133114bcf1d943b/e3980cc0c64bf000877d99276efb4e93.png\" alt=\"静安27.png\" data-size=\"1534233\"></p>\n          <p style=\"text-align: center;\">南京西路上的平安大楼</p>\n          <p>  <strong>行走路线：</strong></p>\n          <p>  静安公园——静安嘉里中心——安义路街区——陕西北路中国历史文化名街——静安雕塑公园——张园</p>\n          <p>  <strong>宝藏点位：</strong></p>\n          <p>  ◆静安公园</p>\n          <p>  在繁华的静安寺商圈，静安公园是一块珍贵的绿地。中外游客与市民在这里漫步、锻炼、看书、遛娃，享受静谧的自然气息。公园里有草坪、石亭、茶室、餐厅，四时花木盛开，小桥流水潺潺。</p>\n          <p>  地址：南京西路1649号</p>\n          <p style=\"text-align: center;\"><img id=\"67d7607f87c0453ab1d135c83f2f3f16\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安28.png\" src=\"/cmsres/67/67d7607f87c0453ab1d135c83f2f3f16/9e3a37f53be99631f98b5178a2ec90d8.png\" alt=\"静安28.png\" data-size=\"2809357\"></p>\n          <p>  ◆静安嘉里中心—安义路街区</p>\n          <p>  地处静安区静安寺商圈的静安嘉里中心—安义路街区，是国家级旅游休闲街区，也是上海旅游休闲文化氛围最浓厚的街区之一。这里既为市民休憩放松提供了开阔的室外场所，还会不定期举办高人气集市“安义夜巷”以及“建筑可阅读”文创市集、上海时装周等各类文化艺术活动。</p>\n          <p>  地址：南京西路1515号</p>\n          <p style=\"text-align: center;\"><img id=\"72e3124d14ee4a3282c3e2efdddca26c\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安29.png\" src=\"/cmsres/72/72e3124d14ee4a3282c3e2efdddca26c/eda54a37e4c65e394b0cc9aaf95bde90.png\" alt=\"静安29.png\" data-size=\"1647269\"></p>\n          <p>  ◆陕西北路中国历史文化名街</p>\n          <p>  陕西北路（巨鹿路—新闸路），旧称西摩路，于1914年筑成，是上海仅有的三条经国家文化部评定的“中国历史文化名街”其中之一，还被列入上海“64条永不拓宽的马路”。</p>\n          <p style=\"text-align: center;\"><img id=\"74529441bea647f9ab4f4a7fa876ece3\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安30.png\" src=\"/cmsres/74/74529441bea647f9ab4f4a7fa876ece3/2aeb61d68de6e4b6a1d3c81c041fa121.png\" alt=\"静安30.png\" data-size=\"3277532\"></p>\n          <p style=\"text-align: center;\"><img id=\"6345114ff4c04faf9265fad1146ded22\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安31.png\" src=\"/cmsres/63/6345114ff4c04faf9265fad1146ded22/362d310bd884bdac77b0473b6b0c8a9e.png\" alt=\"静安31.png\" data-size=\"2290477\"></p>\n          <p>  ◆静安雕塑公园</p>\n          <p>  静安雕塑公园是一个以雕塑为主题，以展示为手段的开放式城市公园。公园内，绿化与雕塑、小品相互渗透、和谐统一。</p>\n          <p>  地址：北京西路510号</p>\n          <p>  ◆张园</p>\n          <p>  2022年12月，张园西区完成保护性修缮，焕新回归大众视野，成为上海城市更新的新范本，繁华更胜往昔。</p>\n          <p>  地址：茂名北路188弄</p>\n          <p style=\"text-align: center;\"><img id=\"ae644885390e422e9af254276708102c\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安32.png\" src=\"/cmsres/ae/ae644885390e422e9af254276708102c/2041fd5c9f4229a2f8be72f4dad406dc.png\" alt=\"静安32.png\" data-size=\"1352147\"></p>\n          <p>  </p>\n          <p style=\"text-align: center;\"><strong>线路四：打卡“文旅+”， 一站式体验“乐在静安”</strong></p>\n          <p>  近年来，静安区牢牢把握文化和旅游产业高质量发展的主旋律和新兴数字文化蓬勃发展的新形势，着力推进“文化+科技”“文旅+消费”等业态模式创新，打造和吸引一批新媒体技术应用、沉浸式体验空间、多业态消费集聚的新型消费场景，培育新型消费形态、创新文旅消费场景，持续增强文旅IP对消费人口的拉动作用。</p>\n          <p>  <strong>行走路线：</strong></p>\n          <p>  静安寺——百乐门——中共上海地下组织斗争史陈列馆暨刘长胜故居——美琪大戏院——星巴克臻选® 上海烘焙工坊——Life Chronicles生命的纪元</p>\n          <p>  <strong>宝藏点位：</strong></p>\n          <p>  ◆静安寺</p>\n          <p>  地址：南京西路1686号</p>\n          <p style=\"text-align: center;\"><img id=\"2adb189fe7bb465ab349d22b03ec705b\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安33.png\" src=\"/cmsres/2a/2adb189fe7bb465ab349d22b03ec705b/f7cb665bffd540a81a37c7fcffddf14b.png\" alt=\"静安33.png\" data-size=\"1552959\"></p>\n          <p>  ◆百乐门</p>\n          <p>  百乐门，全称“百乐门大饭店舞厅”，是上海著名的综合性娱乐场所。</p>\n          <p>  地址：愚园路218号</p>\n          <p style=\"text-align: center;\"><img id=\"f2d01acbac7546219d285fe2f2aec48b\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安34.png\" src=\"/cmsres/f2/f2d01acbac7546219d285fe2f2aec48b/0d0efd497456373989545c900708840d.png\" alt=\"静安34.png\" data-size=\"1347115\"></p>\n          <p>  ◆中共上海地下组织斗争史陈列馆暨刘长胜故居</p>\n          <p>  中共上海地下组织斗争史陈列馆暨刘长胜故居是一幢西班牙式建筑。这里是解放战争时期中国共产党上海局的秘密机关旧址之一，也是刘长胜同志1946年至1949年在上海从事地下革命斗争时的居住地。</p>\n          <p>  地址：愚园路81号</p>\n          <p>  开放时间：周二至周日 9:00—12:00（11:30停止入馆）和13:00—16:30（16:00停止入馆），周一闭馆。</p>\n          <p style=\"text-align: center;\"><img id=\"e6be9edee5e14324b96eb200da9320aa\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安35.png\" src=\"/cmsres/e6/e6be9edee5e14324b96eb200da9320aa/8096847932eb44c095872d37f736fb63.png\" alt=\"静安35.png\" data-size=\"2298862\"></p>\n          <p>  ◆美琪大戏院</p>\n          <p>  美琪大戏院（MAJESTIC THEATRE）建于1941年，1941年10月15日开幕之际，被海内外人士誉为“亚洲第一”“远东最先进的艺术影宫”，也是当时西片放映的首轮影院。</p>\n          <p>  地址：江宁路66号</p>\n          <p style=\"text-align: center;\"><img id=\"4f4636ea0dc545938ca2350c4be2288e\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安36.png\" src=\"/cmsres/4f/4f4636ea0dc545938ca2350c4be2288e/c081a7ec3e2f19cdf4804ed112d642c0.png\" alt=\"静安36.png\" data-size=\"1145379\"></p>\n          <p>  ◆星巴克臻选®上海烘焙工坊</p>\n          <p>  星巴克海外首家臻选烘焙工坊是星巴克亚洲首家全沉浸式咖啡体验门店，也是上海市工业旅游景点。</p>\n          <p>  地址：南京西路789号</p>\n          <p style=\"text-align: center;\"><img id=\"544a2da97e894ee397861aaf6ea88e31\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安37.jpg\" src=\"/cmsres/54/544a2da97e894ee397861aaf6ea88e31/81477f510d68b706b4b4745b5ec8f0ce.jpg\" alt=\"静安37.jpg\" data-size=\"54622\"></p>\n          <p>  ◆Life Chronicles生命的纪元</p>\n          <p>  由230余年岁月沉淀的法国国家自然历史博物馆专业背书，多位古生物学家、古植物学家、进化学家以及生物声学家共同倾力创作的地球生命史诗。短短45分钟的精彩旅程里，观众将穿梭8大纪元，身临其境地领略生命的绚烂与丰饶。</p>\n          <p>  地址：南京西路789号兴业太古汇L3多功能厅</p>\n          <p style=\"text-align: center;\"><img id=\"190f52c51e984342827886182fa83f04\" style=\"max-width: 100%; width: auto; height: auto;\" title=\"静安38.jpg\" src=\"/cmsres/19/190f52c51e984342827886182fa83f04/dd6aa2040eec605d9ffe885dcd029b21.jpg\" alt=\"静安38.jpg\" data-size=\"92103\"></p>\n          <ol class=\"no-border-bottom\">\n          </ol>\n          <ol class=\"no-border-bottom\">\n          </ol>\n         </div>\n        </div>\n       </div>\n      </div><!-- 左侧栏结束 --> <!-- 右侧栏 -->\n      <div class=\"f-right flex-cell\">\n       <!-- 法律知识 -->\n       <div class=\"box list-box\">\n        <p class=\"name\">热点关注</p>\n        <div class=\"content\">\n         <ul>\n          <li class=\"flex-box v-center a-left\" style=\"display:flex;\"><a href=\"https://h.xinhuaxmt.com/vh512/share/12033456?d=134d890&amp;channel=weixin\" title=\"习近平在中共中央政治局第十四次集体学习时强调 促进高质量充分就业 不断增强广大劳动者的获得感幸福感安全感\">习近平在中共中央政治局第十四次集体学习时强调 促进高质量充分就业 不断增强广大...</a></li>\n          <li class=\"flex-box v-center a-left\" style=\"display:flex;\"><a href=\"https://h.xinhuaxmt.com/vh512/share/12031428?d=134d88f&amp;channel=weixin\" title=\"中共中央政治局召开会议 习近平主持会议\">中共中央政治局召开会议 习近平主持会议</a></li>\n          <li class=\"flex-box v-center a-left\" style=\"display:flex;\"><a href=\"https://h.xinhuaxmt.com/vh512/share/12028629?d=134d88c&amp;channel=weixin\" title=\"李强主持召开国务院常务会议\">李强主持召开国务院常务会议</a></li>\n          <li class=\"flex-box v-center a-left\" style=\"display:flex;\"><a href=\"https://h.xinhuaxmt.com/vh512/share/12026829?d=134d88b&amp;channel=weixin\" title=\"习近平主持召开企业和专家座谈会强调 紧扣推进中国式现代化主题 进一步全面深化改革\">习近平主持召开企业和专家座谈会强调 紧扣推进中国式现代化主题 进一步全面深化改...</a></li>\n          <li class=\"flex-box v-center a-left\" style=\"display:flex;\"><a href=\"https://mp.weixin.qq.com/s/ftcTTi0YOFbHe-oJnjlKMw\" title=\"今日重磅！关系保交房、个人房贷，最新政策要点汇总→\">今日重磅！关系保交房、个人房贷，最新政策要点汇总→</a></li>\n         </ul>\n        </div>\n       </div><!-- 法律知识结束 --> <!-- 文物知识 -->\n       <div class=\"box special\">\n        <p class=\"name\">专题报道</p>\n        <div class=\"content swiper\">\n         <div class=\"swiper-container swiper-special\">\n          <div class=\"swiper-wrapper\">\n           <div class=\"swiper-slide\">\n            <div class=\"item\">\n             <a href=\"/cjkehgcdl/\" title=\"长江口二号古船打捞\"><img src=\"/cmsres/af/af3a50398db64bd69142285cc51ae867/531569194dd086f04c17f745fe3356fa.jpg\" alt=\"长江口二号古船打捞\"></a>\n             <div>\n              <a href=\"/cjkehgcdl/\" title=\"长江口二号古船打捞\"> 长江口二号古船打捞 </a>\n             </div>\n            </div>\n           </div>\n           <div class=\"swiper-slide\">\n            <div class=\"item\">\n             <a href=\"http://whlyj.sh.gov.cn/travelBook/index.html\" title=\"旅游安全实务手册\"><img src=\"/cmsres/2a/2a6c5eb752a0491f85d1ae8b374a1926/c4b1d10db9455af88c80648b7ef53b1c.jpg\" alt=\"旅游安全实务手册\"></a>\n             <div>\n              <a href=\"http://whlyj.sh.gov.cn/travelBook/index.html\" title=\"旅游安全实务手册\"> 旅游安全实务手册 </a>\n             </div>\n            </div>\n           </div>\n           <div class=\"swiper-slide\">\n            <div class=\"item\">\n             <a href=\"http://www.meet-in-shanghai.net/\" title=\"文旅对外推广平台\"><img src=\"/cmsres/77/77877e1bf8074f548367494cdc5e07e5/e463e20bbdc51991e82f9bd584d0c0bc.jpg\" alt=\"文旅对外推广平台\"></a>\n             <div>\n              <a href=\"http://www.meet-in-shanghai.net/\" title=\"文旅对外推广平台\"> 文旅对外推广平台 </a>\n             </div>\n            </div>\n           </div>\n          </div>\n         </div>\n         <div class=\"control prev\">\n          <i class=\"iconfont iconxiangshang\"></i>\n         </div>\n         <div class=\"control next\">\n          <i class=\"iconfont iconxiangxia\"></i>\n         </div>\n        </d